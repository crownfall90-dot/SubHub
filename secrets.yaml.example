grizzlysms:
  api_key: YOUR_GRIZZLYSMS_API_KEY
telegram:
  token: YOUR_TELEGRAM_BOT_TOKEN
proxy6:
  api_key: YOUR_PROXY6_API_KEY
github:
  token: YOUR_GITHUB_TOKEN
ggsel:
  api_key: YOUR_GGSEL_API_KEY
  seller_id: 0
  webhook_port: 8765          # порт для приёма POST-уведомлений от GGSell (0 = выключено)
  webhook_secret: ""          # уникальный код продавца для SHA256 (из настроек GGSell → Уведомления)
