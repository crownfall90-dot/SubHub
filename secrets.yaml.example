grizzlysms:
  api_key: ВАШ_API_КЛЮЧ
telegram:
  token: ВАШ_TELEGRAM_BOT_TOKEN
  owner_chat_id: 0             # ваш numeric chat_id; обязателен для первого запуска бота
github:
  token: ВАШ_GITHUB_TOKEN
ggsel:
  api_key: ВАШ_API_КЛЮЧ
  seller_id: ВАШ_SELLER_ID
  webhook_host: 127.0.0.1     # безопасно по умолчанию; внешний reverse proxy настраивается отдельно
  webhook_port: 8765          # порт для приёма POST-уведомлений от GGSell (0 = выключено)
proxy6:
  api_key: ВАШ_PROXY6_API_KEY   # India-прокси для Flipkart OTP (https://proxy6.net)
