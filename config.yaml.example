site:
  url: https://www.flipkart.com/account/login?ret=/
browser:
  headless: false
  profiles_dir: ./chrome_profiles
  timeout: 20000
  slow_mo: 0
  profile_max_age_days: 1.5
  block_media: false
human_behavior:
  delay_between_actions_min: 0.1
  delay_between_actions_max: 0.3
  typing_delay_min: 0.02
  typing_delay_max: 0.05
  delay_between_accounts_min: 1.0
  delay_between_accounts_max: 2.0
grizzlysms:
  api_key: YOUR_GRIZZLYSMS_API_KEY
  service: xt
  country: 22
  max_price: 0.16
  price_tiers:
  - max_price: 0.07
    duration: 8
  - max_price: 0.10
    duration: 8
  - max_price: 0.14
    duration: 8
  - max_price: 0.16
    duration: 0
  parallel_get_slots: 5
  get_number_timeout: 180
  get_number_retry_delay: 2.0
  buy_next_after_seconds: 90
  max_parallel_numbers: 10
  number_lifetime_seconds: 180
  prefetch_lead_seconds: 50
  poll_interval: 1
  get_number_retries: 3
  http_timeout: 30
telegram:
  token: YOUR_TELEGRAM_BOT_TOKEN
telegram_otp:
  wait_timeout: 90
auto_accounts: 10
max_concurrent_accounts: 5
selectors:
  login_button: ''
  username_field: input[placeholder*='Mobile']
  password_field: ''
  submit_button: button:has-text('CONTINUE'), button:has-text('Continue'), button:has-text('Request OTP')
  otp_field: input[type='text']
  otp_submit_button: button:has-text('VERIFY'), button:has-text('Verify'), button:has-text('LOGIN'),
    button:has-text('Signup'), button:has-text('SIGNUP'), button:has-text('CONTINUE'),
    button:has-text('Continue')
  success_indicator: ''
otp:
  mode: api
  manual_prompt: 'Введите OTP для {username}: '
  wait_timeout: 15000
captcha:
  mode: manual
