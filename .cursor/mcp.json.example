{
  "mcpServers": {
    "codebase-memory-mcp": {
      "command": "D:\\tools\\codebase-memory-mcp\\codebase-memory-mcp.exe",
      "args": [],
      "env": {
        "CBM_ALLOWED_ROOT": "${workspaceFolder}",
        "CBM_CACHE_DIR": "D:\\tools\\codebase-memory-mcp\\cache"
      }
    },
    "stitch": {
      "command": "npx",
      "args": ["-y", "@_davideast/stitch-mcp", "proxy"],
      "env": {
        "STITCH_API_KEY": "<YOUR_STITCH_API_KEY>"
      }
    },
    "@21st-dev/magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": "<YOUR_21ST_MAGIC_API_KEY>"
      }
    }
  }
}
